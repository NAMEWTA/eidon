{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "module": "ESNext",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "skipLibCheck": true,

    /* Bundler mode */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",

    /* Path alias for shadcn primitives（其余代码用相对路径）+ 迁移共享模块 @shared */
    "baseUrl": ".",
    "paths": {
      "@/*": ["frontend/*"],
      "@frontend/*": ["frontend/*"],
      "@bridge/*": ["bridge/*"],
      "@shared/*": ["shared/*"]
    },

    /* Linting */
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true
  },
  "include": [
    "frontend/**/*.ts",
    "frontend/**/*.d.ts",
    "frontend/**/*.tsx",
    "bridge/**/*.ts"
  ]
}
