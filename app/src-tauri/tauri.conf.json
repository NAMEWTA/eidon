{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "EIDON",
  "version": "0.0.4",
  "identifier": "app.eidon",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "EIDON",
        "width": 1200,
        "height": 800,
        "minWidth": 480,
        "minHeight": 360,
        "visible": false,
        "center": true
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": [
          "**"
        ]
      }
    }
  },
  "mainBinaryName": "EIDON",
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "Productivity",
    "license": "MIT",
    "publisher": "NAMEWTA",
    "homepage": "https://github.com/NAMEWTA/eidon",
    "shortDescription": "Local-first structured knowledge IDE",
    "longDescription": "EIDON is a local-first structured knowledge IDE for Markdown workspaces with fixed L1/L2/L3 nodes and versioned templates.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installMode": "currentUser",
        "installerIcon": "icons/icon.ico",
        "displayLanguageSelector": false,
        "installerHooks": "installer.nsh"
      }
    },
    "resources": [
      "icons/file_icon.ico",
      "resources/dicts/en_US.aff",
      "resources/dicts/en_US.dic"
    ],
    "macOS": {
      "minimumSystemVersion": "10.15"
    }
  }
}
